{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Camera Configuration",
  "description": "Configuration for a single camera (matches CameraConfigurationJson.java)",
  "type": "object",
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique name of the camera used as subsystem identifier"
    },
    "use": {
      "type": "string",
      "description": "Use case for this camera",
      "enum": [
        "target",
        "apriltag",
        "quest"
      ]
    },
    "strategy": {
      "type": "string",
      "description": "Pose estimation strategy for PhotonVision cameras or YaLL (MEGATAG1/2)",
      "default": "none"
    },
    "column": {
      "type": "integer",
      "description": "SmartDashboard column index for telemetry display",
      "default": 0,
      "minimum": 0
    },
    "pose": {
      "type": "object",
      "description": "Camera pose relative to the robot center",
      "properties": {
        "x": {
          "$ref": "unit-value.schema.json"
        },
        "y": {
          "$ref": "unit-value.schema.json"
        },
        "z": {
          "$ref": "unit-value.schema.json"
        },
        "roll": {
          "$ref": "unit-value.schema.json"
        },
        "pitch": {
          "$ref": "unit-value.schema.json"
        },
        "rotation": {
          "$ref": "unit-value.schema.json"
        }
      }
    },
    "width": {
      "type": "integer",
      "description": "Horizontal resolution of the camera in pixels",
      "default": 800,
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "description": "Vertical resolution of the camera in pixels",
      "default": 600,
      "minimum": 1
    },
    "fov": {
      "type": "number",
      "description": "Camera field of view (degrees)",
      "default": 70
    },
    "targetHeight": {
      "type": "number",
      "description": "Target height in meters",
      "default": 0
    },
    "viewGamePieces": {
      "type": "boolean",
      "description": "Whether to view game pieces in simulation",
      "default": true
    },
    "targetFiducialIds": {
      "type": "array",
      "description": "Optional list of AprilTag IDs to track",
      "items": {
        "type": "integer"
      }
    },
    "yallLedMode": {
      "type": "string",
      "description": "YaLL LED mode"
    },
    "yallStreamMode": {
      "type": "string",
      "description": "YaLL stream mode"
    },
    "yallImuMode": {
      "type": "string",
      "description": "YaLL IMU mode"
    },
    "yallFiducialDownscaling": {
      "type": "string",
      "description": "YaLL fiducial downscaling override"
    },
    "yallPipelineIndex": {
      "type": "integer",
      "description": "YaLL pipeline index override",
      "default": -1
    },
    "yallPriorityTagId": {
      "type": "integer",
      "description": "YaLL priority AprilTag ID override",
      "default": -1
    },
    "yallImuAssistAlpha": {
      "type": "number",
      "description": "YaLL IMU assist alpha value",
      "default": -1
    }
  }
}
